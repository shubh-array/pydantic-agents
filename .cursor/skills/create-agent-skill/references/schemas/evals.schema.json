{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/create-agent-skill/evals.schema.json",
  "oneOf": [
    {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["query", "should_trigger"],
        "properties": {
          "query": {"type": "string", "minLength": 1},
          "should_trigger": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    },
    {
      "type": "object",
      "required": ["queries"],
      "properties": {
        "queries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["query", "should_trigger"],
            "properties": {
              "query": {"type": "string", "minLength": 1},
              "should_trigger": {"type": "boolean"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  ]
}
